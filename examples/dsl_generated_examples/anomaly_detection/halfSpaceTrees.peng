pipeline MyPipeline {
    kafka {
        broker: "localhost:39092"
        input_topic: "anomaly-pred"
        consumer_group: "halfSpaceTree"
    }
    model {

        type : anomaly
        name: HalfSpaceTrees
        params : { 
            n_trees=5
            height=3
            window_size=3
            seed=42
         }

    }



}
